{
    "name": "chatgpt-styler",
    "version": "1.3.1",
    "description": "Extension to allow users to change the styling for their ChatGPT experience.",
    "main": "index.js",
    "packageManager": "npm@11.16.0",
    "engines": {
        "node": ">=24 <25",
        "npm": ">=11"
    },
    "scripts": {
        "build": "npm run build:prod",
        "build:dev": "webpack --config webpack.config.js --mode development",
        "build:prod": "webpack --config webpack.config.js --mode production",
        "dev": "webpack --watch --config webpack.config.js --mode development",
        "test": "jest --config=jest.config.js",
        "test:ci": "jest --config=jest.config.js --ci --coverage=false",
        "typecheck": "tsc --noEmit",
        "lint": "eslint --fix -c ./.eslintrc.js \"src/**/*.ts*\"",
        "lint:check": "eslint -c ./.eslintrc.js \"src/**/*.ts*\"",
        "prettify": "prettier --write \"src/**/*.ts*\"",
        "format:check": "prettier --check \"src/**/*.ts*\"",
        "validate": "npm run typecheck && npm run lint:check && npm run format:check"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/joseph-w-valdez/chatGPTStyler"
    },
    "keywords": [
        "react",
        "typescript",
        "chrome",
        "extension",
        "ChatGPT",
        "UI",
        "personalize",
        "edit",
        "appearance"
    ],
    "author": "Joseph Valdez",
    "license": "MIT",
    "homepage": "https://github.com/joseph-w-valdez/chatGPTStyler",
    "devDependencies": {
        "@types/chrome": "0.0.124",
        "@types/jest": "29.5.14",
        "@types/node": "24.13.3",
        "@types/react": "18.3.18",
        "@types/react-dom": "18.3.5",
        "@types/react-test-renderer": "18.3.1",
        "@typescript-eslint/eslint-plugin": "4.33.0",
        "@typescript-eslint/parser": "4.33.0",
        "autoprefixer": "10.4.27",
        "css-loader": "4.3.0",
        "eslint": "7.32.0",
        "eslint-config-prettier": "6.15.0",
        "eslint-plugin-prettier": "3.4.1",
        "eslint-plugin-react": "7.28.0",
        "identity-obj-proxy": "3.0.0",
        "jest": "29.7.0",
        "jest-environment-jsdom": "29.7.0",
        "postcss": "8.5.19",
        "postcss-loader": "6.2.1",
        "prettier": "2.5.1",
        "react-test-renderer": "18.3.1",
        "style-loader": "3.3.4",
        "tailwindcss": "3.0.8",
        "terser-webpack-plugin": "5.6.1",
        "ts-jest": "29.4.6",
        "ts-loader": "9.5.1",
        "typescript": "4.9.5",
        "webpack": "5.108.4",
        "webpack-cli": "4.10.0"
    },
    "dependencies": {
        "react": "18.3.1",
        "react-dom": "18.3.1"
    },
    "overrides": {
        "braces": "3.0.3",
        "micromatch": "4.0.8",
        "picomatch": "2.3.2",
        "loader-utils": "2.0.4",
        "json5": "2.2.3",
        "cross-spawn": "7.0.6",
        "flatted": "3.4.2",
        "form-data": "4.0.6",
        "ws": "8.21.1",
        "lodash": "4.18.1",
        "minimatch": "3.1.5",
        "postcss": "8.5.19",
        "@tootallnate/once": "3.0.1"
    }
}
